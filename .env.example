# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/database

# Configuracion de sincronizacion de DB
DB_SYNC=false
DB_LOGGING=false

# Entorno
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Supabase Storage
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=uploads

# Brevo (correo transaccional)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Curubande Experience

# Correos de administración (avisos de contacto y reservas), separados por coma
NOTIFICATION_EMAILS=
# Alternativa si ya usas este nombre en otro proyecto:
# ADMIN_EMAILS=

