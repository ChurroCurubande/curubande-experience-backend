# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/database

# Configuracion de sincronizacion de DB
DB_SYNC=false
DB_LOGGING=false

# Entorno
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Supabase Storage
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=uploads

# Brevo (correo transaccional)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Curubande Experience

# Correos de administración (avisos de contacto y reservas), separados por coma
NOTIFICATION_EMAILS=
# Alternativa si ya usas este nombre en otro proyecto:
# ADMIN_EMAILS=

# URL del backend (Railway en prod): base para enlaces “confirmar asistencia” en correos
BACKEND_URL=http://localhost:3000

# URL pública del frontend (Next/Vercel): si se usa para redireccionamiento desde el frontend
PUBLIC_APP_URL=http://localhost:3001

# Zona usada para calcular “mañana” al elegir reservas (debe alinearse con el huso del cron en código: America/Costa_Rica).
# RESERVATION_REMINDER_TIMEZONE=America/Costa_Rica

